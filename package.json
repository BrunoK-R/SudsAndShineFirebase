{
  "name": "sudsandshine-firebase",
  "private": true,
  "scripts": {
    "build:website": "npm --prefix ../Website/sudsandshine run build",
    "sync:website": "rsync -a --delete ../Website/sudsandshine/dist/ public/",
    "prepare:hosting": "npm run build:website && npm run sync:website",
    "deploy:hosting": "firebase deploy --only hosting --project sudsandshine-bd3e2",
    "deploy:all": "firebase deploy --project sudsandshine-bd3e2",
    "migrate:data": "node scripts/migrate-supabase-to-firebase.mjs",
    "test:migration": "node --test tests/migration/*.test.mjs",
    "test:consumer-contract": "node scripts/check-mobile-function-contract.mjs",
    "test:mobile-contract": "node scripts/check-mobile-function-contract.mjs",
    "test:rules": "firebase emulators:exec --only auth,firestore,storage \"node --test --test-concurrency=1 tests/rules/*.test.mjs\"",
    "test:rules:local": "node --test --test-concurrency=1 tests/rules/*.test.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.50.0",
    "firebase-admin": "^14.2.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase": "^11.10.0"
  }
}
