rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isEmployee() {
      return hasRole('employee');
    }

    function isStaff() {
      return isAdmin() || isEmployee();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isShortString(value, minLen, maxLen) {
      return value is string && value.size() >= minLen && value.size() <= maxLen;
    }

    function optionalStringField(key, maxLen) {
      return !request.resource.data.keys().hasAny([key]) ||
        (request.resource.data[key] is string && request.resource.data[key].size() <= maxLen);
    }

    function optionalTimestampField(key) {
      return !request.resource.data.keys().hasAny([key]) ||
        request.resource.data[key] is timestamp;
    }

    function optionalBoolField(key) {
      return !request.resource.data.keys().hasAny([key]) ||
        request.resource.data[key] is bool;
    }

    function optionalOwnerField(userId) {
      return !request.resource.data.keys().hasAny(['ownerUid']) ||
        request.resource.data.ownerUid == userId;
    }

    function isValidPublicReservationCreate() {
      return request.resource.data.keys().hasOnly([
          'reservationCode',
          'customerName',
          'customerEmail',
          'customerPhone',
          'serviceId',
          'serviceName',
          'slotStart',
          'slotEnd',
          'date',
          'status',
          'pendingExpiresAt',
          'notes',
          'createdAt',
          'updatedAt',
          'source',
        ]) &&
        request.resource.data.keys().hasAll([
          'reservationCode',
          'customerName',
          'customerEmail',
          'serviceId',
          'slotStart',
          'slotEnd',
          'date',
          'status',
          'createdAt',
          'updatedAt',
          'source',
        ]) &&
        isShortString(request.resource.data.reservationCode, 5, 24) &&
        isShortString(request.resource.data.customerName, 2, 120) &&
        isShortString(request.resource.data.customerEmail, 5, 320) &&
        isShortString(request.resource.data.serviceId, 1, 120) &&
        isShortString(request.resource.data.slotStart, 10, 64) &&
        isShortString(request.resource.data.slotEnd, 10, 64) &&
        isShortString(request.resource.data.date, 10, 10) &&
        request.resource.data.status == 'pending' &&
        request.resource.data.source == 'public-booking' &&
        request.resource.data.createdAt is timestamp &&
        request.resource.data.updatedAt is timestamp &&
        optionalTimestampField('pendingExpiresAt') &&
        optionalStringField('customerPhone', 40) &&
        optionalStringField('serviceName', 200) &&
        optionalStringField('notes', 2000);
    }

    function isValidNotificationPreferenceWrite(userId) {
      return request.resource.data.keys().hasOnly([
          'ownerUid',
          'bookingStatusEnabled',
          'appointmentReminderEnabled',
          'loyaltyEnabled',
          'adminPendingAlertEnabled',
          'marketingEnabled',
          'updatedAt',
          'updatedByUid',
          'updateSource',
        ]) &&
        optionalOwnerField(userId) &&
        optionalBoolField('bookingStatusEnabled') &&
        optionalBoolField('appointmentReminderEnabled') &&
        optionalBoolField('loyaltyEnabled') &&
        optionalBoolField('adminPendingAlertEnabled') &&
        optionalBoolField('marketingEnabled') &&
        optionalTimestampField('updatedAt') &&
        optionalStringField('updatedByUid', 128) &&
        optionalStringField('updateSource', 80);
    }

    function isValidNotificationTokenWrite(userId) {
      return request.resource.data.keys().hasOnly([
          'ownerUid',
          'tokenId',
          'token',
          'platform',
          'enabled',
          'deviceLabel',
          'appVersion',
          'createdAt',
          'lastSeenAt',
          'updatedAt',
          'revokedAt',
          'updateSource',
        ]) &&
        optionalOwnerField(userId) &&
        optionalStringField('tokenId', 128) &&
        optionalStringField('token', 4096) &&
        optionalStringField('platform', 20) &&
        optionalBoolField('enabled') &&
        optionalStringField('deviceLabel', 120) &&
        optionalStringField('appVersion', 64) &&
        optionalTimestampField('createdAt') &&
        optionalTimestampField('lastSeenAt') &&
        optionalTimestampField('updatedAt') &&
        optionalTimestampField('revokedAt') &&
        optionalStringField('updateSource', 80);
    }

    match /admin_allowlist/{docId} {
      allow read, write: if isAdmin();
    }

    match /services/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /service_extras/{docId} {
      allow read, write: if isAdmin();
    }

    match /portfolio_items/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /business_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin_settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /reservations/{docId} {
      allow create: if isStaff() || isValidPublicReservationCreate();
      allow read, update, delete: if isStaff();
    }

    match /reservation_reviews/{docId} {
      allow read, write: if isStaff();
    }

    match /notification_outbox/{docId} {
      allow read, write: if false;
    }

    match /notification_campaign_drafts/{docId} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read, write: if false;

      match /notification_preferences/{docId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidNotificationPreferenceWrite(userId);
        allow delete: if isOwner(userId);
      }

      match /notification_tokens/{docId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidNotificationTokenWrite(userId);
        allow delete: if isOwner(userId);
      }

      match /{document=**} {
        allow read, write: if false;
      }
    }

    match /blocked_slots/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /workers/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /worker_presence/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /capacity_overrides/{docId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
